<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.utp.meditrackapp.features.dashboard.ui.DashboardController" styleClass="dashboard-root" stylesheets="@styles/global.css,@styles/dashboard.css">
    <BorderPane fx:id="rootPane">
    
    <!-- Top Navbar -->
    <top>
        <fx:include source="navbar.fxml" fx:id="navbar" />
    </top>

    <!-- Sidebar Navigation -->
    <left>
        <fx:include source="sidebar.fxml" fx:id="sidebar" />
    </left>

    <!-- Main Content -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="edge-to-edge">
            <VBox alignment="TOP_CENTER">
                <VBox styleClass="content-area" spacing="30" maxWidth="1400">
                    <!-- Header -->
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label fx:id="welcomeLabel" text="¡Bienvenido de nuevo!" styleClass="title-2" />
                            <Label text="Gestión de Inventario Médico — Sede Central" styleClass="text-muted" />
                        </VBox>
                        <VBox alignment="CENTER_RIGHT" spacing="5">
                            <Label text="Software MediTrack v1.0" styleClass="text-bold, text-accent" />
                            <Label text="Sistema de Control de Postas de Salud" styleClass="text-caption, text-muted" />
                        </VBox>
                    </HBox>

                    <!-- Main Information Section -->
                    <VBox spacing="25">
                        <Label text="Estado del Sistema y Resumen" styleClass="title-3" />
                        <GridPane hgap="25" vgap="25">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="60" minWidth="300" />
                                <ColumnConstraints hgrow="ALWAYS" percentWidth="40" minWidth="300" />
                            </columnConstraints>
                            
                            <!-- Sobre el Sistema -->
                            <VBox GridPane.columnIndex="0" styleClass="card, elevated" spacing="15" style="-fx-min-height: 180;">
                                <Label text="Sobre el Sistema" styleClass="text-bold, card-title-custom" />
                                <Label text="MediTrack optimiza el control de suministros médicos, trazabilidad de lotes y dispensación en tiempo real. Este panel principal le ofrece una visión rápida de la operatividad y guía de uso de su sede." 
                                       wrapText="true" styleClass="text-muted" VBox.vgrow="ALWAYS" />
                            </VBox>
                            
                            <!-- Estado de Conexión -->
                            <VBox GridPane.columnIndex="1" styleClass="card, elevated" spacing="15" style="-fx-min-height: 180;">
                                <Label text="Estado de Conexión" styleClass="text-bold, card-title-custom" />
                                <VBox spacing="12" alignment="CENTER_LEFT" VBox.vgrow="ALWAYS">
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <FontIcon iconLiteral="fas-database" iconSize="18" styleClass="icon-success" />
                                        <Label text="Base de Datos: Conectada" styleClass="text-success, text-bold" />
                                    </HBox>
                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <FontIcon iconLiteral="fas-server" iconSize="18" styleClass="icon-success" />
                                        <Label text="Servidor: Localhost (Active)" styleClass="text-success, text-bold" />
                                    </HBox>
                                </VBox>
                                <Label text="Motor: Docker Desktop Engine" styleClass="text-caption, text-muted" />
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- Module Guide -->
                    <VBox spacing="25">
                        <Label text="Guía de Módulos Operativos" styleClass="title-3" />
                        <FlowPane hgap="25" vgap="25" prefWrapLength="900">
                            <!-- Inventario -->
                            <VBox styleClass="card, elevated, card-info-custom" spacing="15">
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <VBox styleClass="icon-box-subtle">
                                        <FontIcon iconLiteral="fas-box" iconSize="22" styleClass="guide-icon" />
                                    </VBox>
                                    <Label text="Gestión de Inventario" styleClass="text-bold" style="-fx-font-size: 16px;" />
                                </HBox>
                                <Label text="Control total de existencias, registro de movimientos (entradas/salidas) y visualización de alertas de stock crítico." 
                                       wrapText="true" styleClass="text-muted" style="-fx-font-size: 14px;" />
                                <Button text="Ir a Inventario" onAction="#onGoToInventory" styleClass="button, flat, accent" style="-fx-padding: 0;" />
                            </VBox>
                            
                            <!-- Atenciones -->
                            <VBox styleClass="card, elevated, card-info-custom" spacing="15">
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <VBox styleClass="icon-box-subtle">
                                        <FontIcon iconLiteral="fas-heartbeat" iconSize="22" styleClass="guide-icon" />
                                    </VBox>
                                    <Label text="Registro de Atenciones" styleClass="text-bold" style="-fx-font-size: 16px;" />
                                </HBox>
                                <Label text="Registro de recetas médicas y dispensación controlada de medicamentos siguiendo la lógica de vencimiento FEFO." 
                                       wrapText="true" styleClass="text-muted" style="-fx-font-size: 14px;" />
                                <Button text="Ir a Atenciones" onAction="#onGoToAttentions" styleClass="button, flat, accent" style="-fx-padding: 0;" />
                            </VBox>
                            
                            <!-- Reportes -->
                            <VBox styleClass="card, elevated, card-info-custom" spacing="15">
                                <HBox spacing="15" alignment="CENTER_LEFT">
                                    <VBox styleClass="icon-box-subtle">
                                        <FontIcon iconLiteral="fas-file-pdf" iconSize="22" styleClass="guide-icon" />
                                    </VBox>
                                    <Label text="Reportes y Auditoría" styleClass="text-bold" style="-fx-font-size: 16px;" />
                                </HBox>
                                <Label text="Generación de documentos PDF detallados sobre el flujo de medicamentos y movimientos históricos de la sede." 
                                       wrapText="true" styleClass="text-muted" style="-fx-font-size: 14px;" />
                                <Button text="Configurar Reportes" onAction="#onGoToReports" styleClass="button, flat, accent" style="-fx-padding: 0;" />
                            </VBox>
                        </FlowPane>
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
</StackPane>
