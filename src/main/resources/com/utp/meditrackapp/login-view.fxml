<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.utp.meditrackapp.features.auth.ui.LoginController" stylesheets="@styles/login.css">
    <center>
        <HBox spacing="0">
            <!-- Left: form card -->
            <StackPane minWidth="450" prefWidth="520" maxWidth="650" alignment="CENTER" styleClass="left-pane">
                <padding>
                    <Insets left="40" right="20" />
                </padding>
                <VBox alignment="CENTER" spacing="25" maxWidth="380">
                    <VBox alignment="CENTER" spacing="10">
                        <HBox alignment="CENTER" spacing="12">
                            <FontIcon iconLiteral="fas-hand-holding-medical" iconSize="32" styleClass="icon-accent" />
                            <Label styleClass="brand-label">MediTrack</Label>
                        </HBox>
                        <Label text="Iniciar Sesión" styleClass="title-2" />
                        <Label text="Acceso exclusivo para personal autorizado" styleClass="text-muted" textAlignment="CENTER" />
                    </VBox>

                    <VBox styleClass="login-card, elevated" spacing="25">
                        <VBox spacing="18">
                            <VBox spacing="8">
                                <Label text="DNI / IDENTIFICACIÓN" styleClass="grid-label" />
                                <TextField fx:id="dniField" promptText="Ingrese su documento" styleClass="large" onAction="#onDniAction" />
                            </VBox>

                            <VBox spacing="8">
                                <Label text="CONTRASEÑA" styleClass="grid-label" />
                                <HBox spacing="0" alignment="CENTER_LEFT">
                                    <StackPane HBox.hgrow="ALWAYS">
                                        <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="large, left-pill" onAction="#onLogin" />
                                        <TextField fx:id="passwordTextField" promptText="••••••••" visible="false" styleClass="large, left-pill" onAction="#onLogin" />
                                    </StackPane>
                                    <Button fx:id="toggleViewBtn" onAction="#onTogglePasswordVisibility" styleClass="large, right-pill">
                                        <graphic>
                                            <FontIcon fx:id="toggleIcon" iconLiteral="fas-eye" iconSize="16" />
                                        </graphic>
                                    </Button>
                                </HBox>
                            </VBox>
                        </VBox>

                        <Button text="Acceder al Sistema" styleClass="button, accent, large" onAction="#onLogin" maxWidth="Infinity">
                            <graphic>
                                <FontIcon iconLiteral="fas-sign-in-alt" iconColor="white" />
                            </graphic>
                        </Button>

                        <HBox styleClass="info-box" alignment="CENTER_LEFT" spacing="12">
                            <FontIcon iconLiteral="fas-info-circle" iconSize="16" styleClass="icon-muted" />
                            <Label text="El acceso está monitorizado. Si tiene problemas, contacte a soporte IT." wrapText="true" styleClass="text-caption, text-muted" />
                        </HBox>
                    </VBox>

                    <HBox alignment="CENTER" spacing="8" style="-fx-padding: 10 0 0 0;">
                        <FontIcon iconLiteral="fas-copyright" iconSize="12" styleClass="icon-muted" />
                        <Label text="2026 MediTrack. Todos los derechos reservados." styleClass="text-caption, text-muted" />
                    </HBox>
                </VBox>
            </StackPane>

            <!-- Right: visual area -->
            <StackPane styleClass="right-pane" alignment="CENTER" HBox.hgrow="ALWAYS" />
        </HBox>
    </center>
</BorderPane>
