<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.utp.meditrackapp.features.profile.ui.ProfileController"
            styleClass="profile-root" stylesheets="@styles/profile.css">

    <left>
        <VBox styleClass="sidebar" prefWidth="240" spacing="5">
            <padding><Insets top="20" left="0" right="0" bottom="20" /></padding>
            <Label text="MediTrack" styleClass="sidebar-logo" />
            <Label text="Gestión Médica" styleClass="sidebar-sublogo" />

            <Region prefHeight="30" />

            <Button text="Dashboard" styleClass="nav-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-th-large" styleClass="font-icon" /></graphic>
            </Button>
            <Button text="Atención" styleClass="nav-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-user-md" styleClass="font-icon" /></graphic>
            </Button>
            <Button text="Inventario" styleClass="nav-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-boxes" styleClass="font-icon" /></graphic>
            </Button>
            <Button text="Catálogo" styleClass="nav-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-clipboard-list" styleClass="font-icon" /></graphic>
            </Button>
            <Button text="Usuarios" styleClass="nav-button, nav-button-active" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-users" styleClass="font-icon" /></graphic>
            </Button>
            <Button text="Reportes" styleClass="nav-button" maxWidth="Infinity">
                <graphic><FontIcon iconLiteral="fas-chart-bar" styleClass="font-icon" /></graphic>
            </Button>

            <Region VBox.vgrow="ALWAYS" />

            <VBox styleClass="sidebar-footer" spacing="2">
                <Button text="Ajustes" styleClass="nav-button-alt" maxWidth="Infinity">
                    <graphic><FontIcon iconLiteral="fas-cog" styleClass="font-icon" /></graphic>
                </Button>
                <Button text="Cerrar Sesión" styleClass="nav-button-alt" maxWidth="Infinity">
                    <graphic><FontIcon iconLiteral="fas-sign-out-alt" styleClass="font-icon" /></graphic>
                </Button>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="0" styleClass="main-content">
            <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="15">
                <padding><Insets left="25" right="25" /></padding>
                <VBox alignment="CENTER_LEFT">
                    <Label text="Perfil de Usuario" styleClass="header-title" />
                    <Label text="Dashboard / Configuración de Perfil" styleClass="header-breadcrumb" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField promptText="Buscar..." styleClass="search-field" />
                <Button styleClass="icon-button"><graphic><FontIcon iconLiteral="fas-bell" styleClass="font-icon" /></graphic></Button>
                <Button styleClass="icon-button"><graphic><FontIcon iconLiteral="fas-question-circle" styleClass="font-icon" /></graphic></Button>
                <HBox spacing="10" alignment="CENTER">
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Alejandro Rivas" styleClass="user-name-small" />
                        <Label text="Administrator | Sede Central" styleClass="user-role-small" />
                    </VBox>
                    <Circle radius="18" styleClass="avatar-mini" />
                </HBox>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll">
                <GridPane hgap="25" vgap="25">
                    <padding><Insets top="25" right="25" bottom="25" left="25" /></padding>
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30" />
                        <ColumnConstraints percentWidth="70" />
                    </columnConstraints>

                    <VBox spacing="25" GridPane.columnIndex="0">
                        <VBox styleClass="card, profile-card" alignment="CENTER" spacing="10">
                            <StackPane styleClass="avatar-stack">
                                <Circle radius="50" styleClass="avatar-large" />
                                <Button styleClass="btn-camera-edit" StackPane.alignment="BOTTOM_RIGHT">
                                    <graphic><FontIcon iconLiteral="fas-camera" styleClass="font-icon" /></graphic>
                                </Button>
                            </StackPane>
                            <Label text="Dr. Alejandro Rivas" styleClass="user-name-large" />
                            <Label text="Administrator" styleClass="user-role-label" />
                            <HBox alignment="CENTER" spacing="5" styleClass="location-badge">
                                <FontIcon iconLiteral="fas-map-marker-alt" styleClass="font-icon" />
                                <Label text="Sede Central" />
                            </HBox>
                        </VBox>

                        <VBox styleClass="card" spacing="15">
                            <Label text="Resumen de Actividad" styleClass="card-title" />
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Último Acceso" styleClass="activity-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Label text="Hoy, 08:45 AM" styleClass="activity-value" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Reportes Generados" styleClass="activity-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Label text="124" styleClass="activity-value" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT">
                                <Label text="Estado de Cuenta" styleClass="activity-label" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                <Label text="ACTIVO" styleClass="status-badge-active" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <VBox spacing="25" GridPane.columnIndex="1">
                        <VBox styleClass="card" spacing="20">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <FontIcon iconLiteral="fas-user-circle" iconSize="20" styleClass="font-icon" />
                                <Label text="Información Personal" styleClass="card-title" />
                            </HBox>
                            <GridPane hgap="20" vgap="15">
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Nombre Completo" styleClass="input-label" />
                                    <TextField text="Alejandro Rivas Montalvo" styleClass="flat-text-field" />
                                </VBox>
                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="DNI / Identificación" styleClass="input-label" />
                                    <TextField text="78445210-K" styleClass="flat-text-field" />
                                </VBox>
                                <VBox GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <Label text="Correo Electrónico" styleClass="input-label" />
                                    <TextField text="a.rivas@meditrack.system" styleClass="flat-text-field" />
                                </VBox>
                                <VBox GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <Label text="Teléfono de Contacto" styleClass="input-label" />
                                    <TextField text="+56 9 8877 6655" styleClass="flat-text-field" />
                                </VBox>
                            </GridPane>
                        </VBox>

                        <VBox styleClass="card" spacing="15">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <FontIcon iconLiteral="fas-shield-alt" iconSize="20" styleClass="font-icon" />
                                <Label text="Seguridad y Acceso" styleClass="card-title" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="list-item-row">
                                <FontIcon iconLiteral="fas-key" styleClass="row-icon"/>
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Contraseña de Usuario" styleClass="row-main-text" />
                                    <Label text="Actualizada hace 45 días" styleClass="row-sub-text" />
                                </VBox>
                                <Button text="Cambiar Contraseña" styleClass="btn-secondary" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="list-item-row">
                                <FontIcon iconLiteral="fas-mobile-alt" styleClass="row-icon"/>
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Autenticación de Dos Factores (2FA)" styleClass="row-main-text" />
                                    <Label text="Activado vía SMS / App" styleClass="row-sub-text-active" />
                                </VBox>
                                <Button text="Configurar" styleClass="btn-secondary" />
                            </HBox>
                        </VBox>

                        <VBox styleClass="card" spacing="15">
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <FontIcon iconLiteral="fas-sliders-h" iconSize="20" styleClass="font-icon" />
                                <Label text="Preferencias del Sistema" styleClass="card-title" />
                            </HBox>
                            <HBox spacing="20">
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Idioma del Interfaz" styleClass="input-label" />
                                    <ComboBox maxWidth="Infinity" promptText="Español (Latinoamérica)" />
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Frecuencia de Notificaciones" styleClass="input-label" />
                                    <ComboBox maxWidth="Infinity" promptText="Inmediatas" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox styleClass="card-danger" spacing="10">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontIcon iconLiteral="fas-exclamation-triangle" iconColor="FIREBRICK" styleClass="font-icon" />
                                <Label text="Acciones de Cuenta" styleClass="card-title-danger" />
                            </HBox>
                            <HBox alignment="CENTER_LEFT">
                                <VBox HBox.hgrow="ALWAYS">
                                    <Label text="Cerrar Sesión Global" styleClass="row-main-text" />
                                    <Label text="Finaliza todas las sesiones activas en cualquier dispositivo." styleClass="row-sub-text" />
                                </VBox>
                                <Button text="Cerrar Todas las Sesiones" styleClass="btn-danger" />
                            </HBox>
                        </VBox>
                    </VBox>
                </GridPane>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>