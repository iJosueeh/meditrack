<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" 
           fx:controller="com.utp.meditrackapp.features.attentions.ui.AtencionController" 
           styleClass="dashboard-root" stylesheets="@styles/global.css,@styles/dashboard.css,@styles/inventory.css">
    
    <BorderPane fx:id="rootPane">
        <top>
            <fx:include source="navbar.fxml" fx:id="navbar" />
        </top>
        <left>
            <fx:include source="sidebar.fxml" fx:id="sidebar" />
        </left>
        <center>
            <ScrollPane fitToWidth="true" styleClass="edge-to-edge">
                <VBox styleClass="content-area" spacing="25" maxWidth="1400">
                    <padding><Insets top="20" right="20" bottom="20" left="20" /></padding>
                    
                    <!-- Header -->
                    <VBox spacing="4">
                        <Label text="Atención y Dispensación" styleClass="title-2" />
                        <Label text="Registre la entrega de medicamentos basada en recetas médicas." styleClass="text-muted" wrapText="true" />
                    </VBox>

                    <!-- Tabs -->
                    <TabPane fx:id="atencionTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                        <tabs>

                            <!-- ==================== TAB ATENCIONES ==================== -->
                            <Tab text="Atenciones">
                                <VBox spacing="15" style="-fx-padding: 25 0 0 0;">
                                    <!-- Search bar -->
                                    <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
                                        <TextField fx:id="txtSearchPaciente" promptText="Buscar por DNI o nombre del paciente..." HBox.hgrow="ALWAYS" onKeyReleased="#onSearchPacienteKey" />
                                        <Button text="Consultar" onAction="#onBuscarAtenciones" styleClass="button, accent">
                                            <graphic><FontIcon iconLiteral="fas-search" iconColor="white" /></graphic>
                                        </Button>
                                        <Button text="Limpiar" onAction="#onLimpiarBusqueda" styleClass="button, flat">
                                            <graphic><FontIcon iconLiteral="fas-eraser" iconColor="#6b7280" /></graphic>
                                        </Button>
                                    </HBox>

                                    <!-- Info del paciente seleccionado -->
                                    <HBox fx:id="hboxPacienteInfo" visible="false" managed="false" alignment="CENTER_LEFT" spacing="10" styleClass="bg-success-subtle" style="-fx-padding: 10 15; -fx-background-radius: 8;">
                                        <FontIcon iconLiteral="fas-user-check" styleClass="icon-success" />
                                        <Label fx:id="lblPacienteInfo" text="" styleClass="text-bold" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblAtencionesCount" text="" styleClass="text-caption, text-muted" />
                                    </HBox>

                                    <!-- Tabla de atenciones -->
                                    <TableView fx:id="tableHistorial" VBox.vgrow="ALWAYS" fixedCellSize="45">
                                        <columns>
                                            <TableColumn fx:id="colHistFecha" text="FECHA" prefWidth="160" />
                                            <TableColumn fx:id="colHistReceta" text="N° RECETA" prefWidth="160" />
                                            <TableColumn fx:id="colHistMedico" text="MÉDICO" prefWidth="200" />
                                            <TableColumn fx:id="colHistAcciones" text="ACCIONES" prefWidth="140" sortable="false" />
                                        </columns>
                                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                        <placeholder>
                                            <Label text="Ingrese un DNI o nombre y presione Consultar para ver las atenciones." styleClass="text-muted" />
                                        </placeholder>
                                    </TableView>
                                </VBox>
                            </Tab>

                            <!-- ==================== TAB DISPENSACIÓN ==================== -->
                            <Tab text="Dispensación">
                                <VBox spacing="15" style="-fx-padding: 25 0 0 0;">
                                    <!-- Search bar -->
                                    <HBox styleClass="filter-bar" spacing="10" alignment="CENTER_LEFT">
                                        <TextField fx:id="txtBusquedaPacienteDisp" promptText="Buscar por DNI o nombre del paciente..." HBox.hgrow="ALWAYS" onKeyReleased="#onSearchPacienteDispKey" />
                                        <Button text="Consultar" onAction="#onBuscarPacienteDisp" styleClass="button, accent">
                                            <graphic><FontIcon iconLiteral="fas-search" iconColor="white" /></graphic>
                                        </Button>
                                        <Button text="Limpiar" onAction="#onLimpiarBusquedaDisp" styleClass="button, flat">
                                            <graphic><FontIcon iconLiteral="fas-eraser" iconColor="#6b7280" /></graphic>
                                        </Button>
                                    </HBox>

                                    <!-- Info del paciente seleccionado -->
                                    <HBox fx:id="hboxPacienteInfoDisp" visible="false" managed="false" alignment="CENTER_LEFT" spacing="15" styleClass="bg-success-subtle" style="-fx-padding: 10 15; -fx-background-radius: 8;">
                                        <FontIcon iconLiteral="fas-user-check" styleClass="icon-success" />
                                        <Label fx:id="lblPatientNameDisp" text="" styleClass="text-bold" />
                                        <Label fx:id="lblPatientPhoneDisp" text="" styleClass="text-muted" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblRecetaNum" text="" styleClass="text-bold" style="-fx-text-fill: #2563eb;" />
                                    </HBox>

                                    <!-- Agregar medicamento -->
                                    <HBox styleClass="card, elevated" spacing="12" alignment="BOTTOM_LEFT">
                                        <VBox spacing="4" maxWidth="180">
                                            <Label text="MÉDICO" styleClass="text-caption, text-muted" />
                                            <TextField fx:id="txtMedico" promptText="Opcional" />
                                        </VBox>
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <Label text="PRODUCTO" styleClass="text-caption, text-muted" />
                                            <ComboBox fx:id="cmbProducto" maxWidth="Infinity" promptText="Seleccione medicamento..." onAction="#onProductoSelected" />
                                        </VBox>
                                        <VBox spacing="4" maxWidth="90">
                                            <Label text="CANTIDAD" styleClass="text-caption, text-muted" />
                                            <TextField fx:id="txtCantidad" promptText="0" />
                                        </VBox>
                                        <Button text="Agregar" onAction="#onAddToBasket" styleClass="button, accent" />
                                    </HBox>
                                    <!-- Selección de lote FEFO -->
                                    <HBox spacing="10" alignment="CENTER_LEFT" visible="false" managed="false" fx:id="hboxLoteSelect">
                                        <VBox spacing="2" HBox.hgrow="ALWAYS">
                                            <Label text="LOTE (FEFO)" styleClass="text-caption, text-bold, text-muted" />
                                            <ComboBox fx:id="cmbLote" maxWidth="Infinity" promptText="Seleccione producto primero..." />
                                        </VBox>
                                    </HBox>

                                    <!-- Canasta -->
                                    <VBox styleClass="card, elevated" spacing="12" VBox.vgrow="ALWAYS">
                                        <HBox alignment="CENTER_LEFT" spacing="10">
                                            <Label text="DETALLE DE DISPENSACIÓN" styleClass="text-caption, text-bold, text-muted" />
                                            <Region HBox.hgrow="ALWAYS" />
                                            <Label fx:id="lblItemsCount" text="0 ítems" styleClass="text-caption, text-muted" />
                                        </HBox>
                                        
                                        <TableView fx:id="tableBasket" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colBasketProduct" text="Producto" prefWidth="280" />
                                                <TableColumn fx:id="colBasketLote" text="Lote" prefWidth="130" />
                                                <TableColumn fx:id="colBasketExp" text="Vencimiento" prefWidth="120" />
                                                <TableColumn fx:id="colBasketQty" text="Cant." prefWidth="70" />
                                                <TableColumn fx:id="colBasketAction" text="" prefWidth="50" />
                                            </columns>
                                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                                            <placeholder>
                                                <Label text="No hay productos en la canasta." styleClass="text-muted" />
                                            </placeholder>
                                        </TableView>

                                        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
                                            <VBox alignment="CENTER_RIGHT">
                                                <Label text="TOTAL A DISPENSAR" styleClass="text-caption, text-muted" />
                                                <Label fx:id="lblTotalDispensed" text="0" styleClass="title-3" />
                                            </VBox>
                                            <Button text="Confirmar Atención" onAction="#onConfirmarEntrega" styleClass="button, accent, large" />
                                        </HBox>
                                    </VBox>
                                </VBox>
                            </Tab>
                        </tabs>
                    </TabPane>
                </VBox>
            </ScrollPane>
        </center>
    </BorderPane>

    <!-- Modal: Ver Detalle -->
    <StackPane fx:id="modalDetalle" visible="false" styleClass="modal-overlay">
        <VBox maxWidth="700" maxHeight="-Infinity" styleClass="modal-content" spacing="20">
            <VBox styleClass="modal-header">
                <Label fx:id="lblDetalleTitle" text="Detalle de Atención" styleClass="title-4" />
                <Label fx:id="lblDetalleSub" text="" styleClass="text-muted" />
            </VBox>
            <TableView fx:id="tableDetalle" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colDetProducto" text="Producto" prefWidth="250" />
                    <TableColumn fx:id="colDetLote" text="Lote" prefWidth="120" />
                    <TableColumn fx:id="colDetVencimiento" text="Vencimiento" prefWidth="110" />
                    <TableColumn fx:id="colDetCantidad" text="Cantidad" prefWidth="80" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
            <HBox alignment="CENTER_RIGHT">
                <Button text="Cerrar" onAction="#onCloseDetalle" styleClass="button, flat" />
            </HBox>
        </VBox>
    </StackPane>

    <!-- Modal: Editar Atención -->
    <StackPane fx:id="modalEditar" visible="false" styleClass="modal-overlay">
        <VBox maxWidth="750" maxHeight="-Infinity" styleClass="modal-content" spacing="20">
            <VBox styleClass="modal-header">
                <Label text="Editar Atención" styleClass="title-4" />
                <Label fx:id="lblEditarSub" text="" styleClass="text-muted" />
            </VBox>
            <VBox spacing="12">
                <VBox spacing="4">
                    <Label text="N° RECETA" styleClass="text-caption, text-bold, text-muted" />
                    <TextField fx:id="txtEditReceta" maxWidth="Infinity" />
                </VBox>
                <VBox spacing="4">
                    <Label text="MÉDICO" styleClass="text-caption, text-bold, text-muted" />
                    <TextField fx:id="txtEditMedico" maxWidth="Infinity" />
                </VBox>
            </VBox>

            <!-- Detalle de medicamentos editable -->
            <VBox spacing="6">
                <Label text="DETALLE DE MEDICAMENTOS" styleClass="text-caption, text-bold, text-muted" />
                <TableView fx:id="tableEditDetalle" prefHeight="180" maxWidth="Infinity">
                    <columns>
                        <TableColumn fx:id="colEditProducto" text="Producto" prefWidth="220" />
                        <TableColumn fx:id="colEditLote" text="Lote" prefWidth="250" />
                        <TableColumn fx:id="colEditCantidad" text="Cantidad" prefWidth="100" />
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <placeholder>
                        <Label text="Esta atención no tiene medicamentos registrados." styleClass="text-muted" />
                    </placeholder>
                </TableView>
            </VBox>

            <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="modal-footer">
                <Button text="Cancelar" onAction="#onCloseEditar" styleClass="button, flat" />
                <Button text="Guardar" onAction="#onSaveEditar" styleClass="button, accent" />
            </HBox>
        </VBox>
    </StackPane>
</StackPane>
