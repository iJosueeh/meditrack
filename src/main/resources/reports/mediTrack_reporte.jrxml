                <text><![CDATA[CÓDIGO]]></text>
            </staticText>
            <staticText>
                <reportElement style="TableHeader" x="80" y="5" width="200" height="25" uuid="a2b3c4d5-e6f7-4890-8012-2345678901fc"/>
                <textElement verticalAlignment="Middle"/>
                <text><![CDATA[PRODUCTO]]></text>
            </staticText>
            <staticText>
                <reportElement style="TableHeader" x="280" y="5" width="130" height="25" uuid="b3c4d5e6-f7a8-4901-8012-3456789012ad"/>
                <textElement verticalAlignment="Middle"/>
                <text><![CDATA[CATEGORÍA]]></text>
            </staticText>
            <staticText>
                <reportElement style="TableHeader" x="410" y="5" width="60" height="25" uuid="c4d5e6f7-a8b9-4012-8012-4567890123be"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[STOCK]]></text>
            </staticText>
            <staticText>
                <reportElement style="TableHeader" x="470" y="5" width="85" height="25" uuid="d5e6f7a8-b9c0-4123-8012-5678901234cf"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[ESTADO]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="30" splitType="Stretch">
            <rectangle>
                <reportElement style="TableRow" mode="Opaque" x="0" y="0" width="555" height="30" uuid="e6f7a8b9-c0d1-4234-8012-6789012345da"/>
                <graphicElement><pen lineWidth="0"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="10" y="0" width="70" height="30" uuid="f7a8b9c0-d1e2-4345-8012-7890123456eb"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{code}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80" y="0" width="200" height="30" uuid="a8b9c0d1-e2f3-4456-8012-8901234567fa"/>
                <textElement verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
